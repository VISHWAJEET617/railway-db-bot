# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_ID=123456789

# ── Optional ──────────────────────────────────────────────────────────────────
# Telegram channel/group ID for live event logs (leave blank to disable)
LOG_CHANNEL_ID=

# Seconds between /getdb requests per user (default: 300)
COOLDOWN_SECS=300

# Override Chromium binary path (default: auto-detect)
# CHROMIUM_PATH=/usr/bin/chromium

# Override SQLite file path (default: data/bot_data.db)
# DB_PATH=data/bot_data.db
